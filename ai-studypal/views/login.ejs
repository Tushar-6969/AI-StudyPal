<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Login | AI StudyPal</title>
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="/css/styles.css">
</head>
<body>
  <nav class="navbar navbar-expand-lg navbar-dark py-3">
    <div class="container">
      <a class="navbar-brand" href="/">AI StudyPal</a>
      <div class="ms-auto">
        <a class="btn btn-soft-light btn-sm" href="/signup">Create account</a>
      </div>
    </div>
  </nav>

  <% if (success && success.length > 0) { %>
    <div class="alert alert-success text-center rounded-0 m-0">
      <%= success %>
    </div>
  <% } %>
  <% if (error && error.length > 0) { %>
    <div class="alert alert-danger text-center rounded-0 m-0">
      <%= error %>
    </div>
  <% } %>

  <main class="auth-shell">
    <div class="auth-card">
      <div class="auth-hero">
        <span class="badge-soft">Welcome back</span>
        <h2>Login to AI StudyPal</h2>
        <p>Access your saved conversations, profile, and secure AI-powered study help.</p>
        <div class="feature-box">
          <h5>Secure access</h5>
          <p>Login with your email and password or use Google for one-click access.</p>
        </div>
      </div>

      <form action="/login" method="POST" class="auth-form">
        <div>
          <label for="username" class="form-label">Username</label>
          <input type="text" id="username" name="username" class="form-control" required>
        </div>
        <div>
          <label for="password" class="form-label">Password</label>
          <input type="password" id="password" name="password" class="form-control" required>
        </div>
        <button type="submit" class="btn btn-primary btn-lg w-100">Login</button>
        <div class="text-center my-3 text-muted">OR</div>
        <a href="/auth/google" class="google-btn">
          <img class="google-icon" src="https://img.icons8.com/?size=100&id=17949&format=png&color=000000" alt="Google Logo">
          <span>Continue with Google</span>
        </a>
        <p class="text-center text-muted mt-4">Don’t have an account? <a class="auth-link" href="/signup">Register here</a></p>
      </form>
    </div>
  </main>

  <footer class="footer">
    © <%= new Date().getFullYear() %> AI StudyPal
  </footer>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
