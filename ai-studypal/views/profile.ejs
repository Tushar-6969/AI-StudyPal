<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>My Profile | AI StudyPal</title>
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="/css/styles.css">
</head>
<body>
  <nav class="navbar navbar-expand-lg navbar-dark py-3">
    <div class="container">
      <a class="navbar-brand" href="/">AI StudyPal</a>
      <div class="ms-auto">
        <a class="btn btn-soft-light btn-sm" href="/">Home</a>
      </div>
    </div>
  </nav>

  <main class="container py-5">
    <section class="page-card p-4">
      <div class="row g-4 align-items-start">
        <div class="col-lg-4 text-center">
          <img src="<%= user.profilePic ? user.profilePic : '/images/profile.jpg' %>" class="rounded-circle mb-3" width="160" height="160" style="object-fit: cover; border: 4px solid rgba(255,255,255,0.14);">
          <h3 class="mt-2">@<%= user.username %></h3>
          <p class="text-muted mb-1">Joined: <%= new Date(user.createdAt).toDateString() %></p>
          <span class="badge-soft">Active user</span>
        </div>
        <div class="col-lg-8">
          <div class="profile-grid p-4 mb-4">
            <h4 class="section-title">Bio</h4>
            <p class="text-muted"><%= user.bio ? user.bio : 'No bio added yet.' %></p>
          </div>
          <div class="row g-4">
            <div class="col-md-6">
              <div class="glass-panel p-4 h-100">
                <h5>Update Bio</h5>
                <form action="/profile/update" method="POST">
                  <div class="mb-3">
                    <textarea name="bio" class="form-control" rows="4" placeholder="Tell us about yourself..."></textarea>
                  </div>
                  <button class="btn btn-primary w-100">Save bio</button>
                </form>
              </div>
            </div>
            <div class="col-md-6">
              <div class="glass-panel p-4 h-100">
                <h5>Change profile picture</h5>
                <form action="/profile/upload-photo" method="POST" enctype="multipart/form-data">
                  <div class="mb-3">
                    <input type="file" name="profilePic" class="form-control" required>
                  </div>
                  <button class="btn btn-primary w-100">Upload photo</button>
                </form>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>
  </main>

  <footer class="footer">
    © <%= new Date().getFullYear() %> AI StudyPal
  </footer>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
