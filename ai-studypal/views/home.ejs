<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>AI StudyPal</title>
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="/css/styles.css">
</head>
<body>
  <nav class="navbar navbar-expand-lg navbar-dark py-3">
    <div class="container">
      <a class="navbar-brand" href="/">AI StudyPal</a>
      <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navMenu">
        <span class="navbar-toggler-icon"></span>
      </button>

      <div class="collapse navbar-collapse" id="navMenu">
        <div class="ms-auto d-flex align-items-center gap-2">
          <% if (user) { %>
            <a class="btn btn-outline-light btn-sm" href="/previous-chats">Previous chats</a>
            <a class="btn btn-primary btn-sm" href="/new-chat">New chat</a>
            <div class="dropdown">
              <a class="btn btn-soft-light btn-sm dropdown-toggle d-flex align-items-center" href="#" role="button" data-bs-toggle="dropdown">
                <img src="<%= user.profilePic ? user.profilePic : '/images/profile.jpg' %>" class="rounded-circle me-2" width="34" height="34" style="object-fit: cover;">
                <span><%= user.username %></span>
              </a>
              <ul class="dropdown-menu dropdown-menu-end mt-2">
                <li><a class="dropdown-item" href="/profile/me">My Profile</a></li>
                <li><hr class="dropdown-divider"></li>
                <li><a class="dropdown-item text-danger" href="/logout">Logout</a></li>
              </ul>
            </div>
          <% } else { %>
            <a class="btn btn-soft-light btn-sm" href="/login">Login</a>
            <a class="btn btn-primary btn-sm" href="/signup">Sign up</a>
          <% } %>
        </div>
      </div>
    </div>
  </nav>

  <% if (success && success.length > 0) { %>
    <div class="alert alert-success text-center rounded-0 m-0">
      <%= success %>
    </div>
  <% } %>

  <% if (error && error.length > 0) { %>
    <div class="alert alert-danger text-center rounded-0 m-0">
      <%= error %>
    </div>
  <% } %>

  <main class="container py-5">
    <section class="page-card hero-card p-5 mb-5">
      <div class="row align-items-center gy-4 hero-row">
        <div class="col-lg-7 hero-copy">
          <span class="badge-soft mb-3">AI-powered study assistant</span>
          <h1 class="mb-4">Study smarter with AI-crafted answers, explanations, and notes.</h1>
          <p class="text-muted mb-4">Upload PDFs, images, or ask any question to get instant study support from AI StudyPal. Designed to help learners stay confident, organized, and focused.</p>
          <div class="d-flex flex-wrap gap-3">
            <div class="feature-box">
              <h5>Fast answers</h5>
              <p>Get clear explanations and summaries in seconds.</p>
            </div>
            <div class="feature-box">
              <h5>Smart uploads</h5>
              <p>Share PDFs or images and let StudyPal analyze them for you.</p>
            </div>
          </div>
        </div>
        <div class="col-lg-5 hero-visual">
          <div class="page-card p-4 h-100">
            <h3 class="section-title">Ready to learn?</h3>
            <p class="text-muted">Log in or sign up to access your saved chats, profile, and personalized study recommendations.</p>
            <div class="mt-4">
              <% if (!user) { %>
                <a class="btn btn-primary btn-lg w-100 mb-3" href="/signup">Create account</a>
                <a class="btn btn-soft-light btn-lg w-100" href="/login">Already have an account?</a>
              <% } else { %>
                <a class="btn btn-primary btn-lg w-100 mb-3" href="/previous-chats">Continue where you left off</a>
              <% } %>
            </div>
          </div>
        </div>
      </div>
    </section>

    <div class="row gy-4">
      <div class="col-lg-7">
        <section class="page-card p-4">
          <h2 class="section-title">Ask StudyPal</h2>
          <form action="/" method="POST" enctype="multipart/form-data">
            <div class="mb-4">
              <label class="form-label">What do you want to learn today?</label>
              <input type="text" name="question" class="form-control form-control-lg" placeholder="Explain neural networks for beginners..." required>
            </div>
            <div class="row g-3 mb-4">
              <div class="col-md-6">
                <label class="form-label">Upload PDF</label>
                <input type="file" name="pdf" accept="application/pdf" class="form-control">
              </div>
              <div class="col-md-6">
                <label class="form-label">Upload image</label>
                <input type="file" name="image" accept="image/*" class="form-control">
              </div>
            </div>
            <button type="submit" class="btn btn-primary btn-lg w-100">Ask StudyPal</button>
            <div id="loading-spinner" class="text-center my-4" style="display: none;">
              <div class="spinner-border text-primary" role="status"></div>
              <p class="mt-2 text-muted">StudyPal is thinking...</p>
            </div>
          </form>
        </section>
      </div>
      <div class="col-lg-5">
        <section class="page-card p-4">
          <h2 class="section-title">Why use StudyPal?</h2>
          <div class="feature-box">
            <h5>Organized responses</h5>
            <p>Turn complex topics into easy-to-read answers.</p>
          </div>
          <div class="feature-box">
            <h5>Upload files</h5>
            <p>Include lecture notes, textbooks, or images for tailored help.</p>
          </div>
          <div class="feature-box">
            <h5>Save your chats</h5>
            <p>Keep track of your previous conversations and study progress.</p>
          </div>
        </section>
      </div>
    </div>

    <% if (conversation && conversation.length > 0) { %>
      <section class="mt-5" id="response-section">
        <h2 class="section-title text-center">Recent conversation</h2>
        <div class="row gy-4">
          <% conversation.forEach(pair => { %>
            <div class="col-12">
              <article class="chat-card">
                <div class="message-label">🧑 You</div>
                <div class="message-body mb-3"><%= pair.prompt %></div>
                <div class="message-label">🤖 StudyPal</div>
                <div class="message-body"><%- pair.response %></div>
              </article>
            </div>
          <% }) %>
        </div>
      </section>
    <% } %>
  </main>

  <footer class="footer">
    <div class="container text-center">
      © <%= new Date().getFullYear() %> AI StudyPal | Built by Tushar Rathor
    </div>
  </footer>

  <script src="/js/script.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
