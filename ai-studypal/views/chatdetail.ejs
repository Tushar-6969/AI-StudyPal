<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Chat Details | AI StudyPal</title>
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="/css/styles.css">
</head>
<body>
  <nav class="navbar navbar-expand-lg navbar-dark py-3">
    <div class="container">
      <a class="navbar-brand" href="/">AI StudyPal</a>
      <div class="ms-auto">
        <a class="btn btn-soft-light btn-sm" href="/previous-chats">Back to Chats</a>
      </div>
    </div>
  </nav>

  <main class="container py-5">
    <section class="page-card p-4">
      <h1 class="section-title">Chat details</h1>

      <% if (chat && chat.conversation && chat.conversation.length > 0) { %>
        <div class="row g-4">
          <% chat.conversation.forEach(pair => { %>
            <div class="col-12">
              <article class="chat-card">
                <p class="message-label">🧑 You</p>
                <div class="message-body"><%= pair.prompt %></div>
                <hr class="border-secondary opacity-25">
                <p class="message-label">🤖 StudyPal</p>
                <div class="message-body"><%- pair.response %></div>
              </article>
            </div>
          <% }) %>
        </div>
      <% } else { %>
        <p class="text-muted">No conversation data available for this chat.</p>
      <% } %>

      <div class="text-end mt-4">
        <a href="/previous-chats" class="btn btn-primary">← Back to Previous Chats</a>
      </div>
    </section>
  </main>

  <footer class="footer">
    © <%= new Date().getFullYear() %> AI StudyPal
  </footer>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
