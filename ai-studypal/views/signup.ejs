<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Sign Up | AI StudyPal</title>
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="/css/styles.css">
</head>
<body>
  <nav class="navbar navbar-expand-lg navbar-dark py-3">
    <div class="container">
      <a class="navbar-brand" href="/">AI StudyPal</a>
      <div class="ms-auto">
        <a class="btn btn-soft-light btn-sm" href="/login">Already have an account?</a>
      </div>
    </div>
  </nav>

  <% if (success && success.length > 0) { %>
    <div class="alert alert-success text-center rounded-0 m-0">
      <%= success %>
    </div>
  <% } %>
  <% if (error && error.length > 0) { %>
    <div class="alert alert-danger text-center rounded-0 m-0">
      <%= error %>
    </div>
  <% } %>

  <main class="auth-shell">
    <div class="auth-card">
      <div class="auth-hero">
        <span class="badge-soft">Join AI StudyPal</span>
        <h2>Create your learning workspace</h2>
        <p>Sign up in seconds and start using AI to simplify study notes, solve problems, and review course material faster.</p>
        <div class="feature-box">
          <h5>Instant setup</h5>
          <p>Register and begin asking questions right away with no friction.</p>
        </div>
      </div>

      <form action="/signup" method="POST" class="auth-form">
        <div>
          <label for="username" class="form-label">Username</label>
          <input type="text" id="username" name="username" class="form-control" required>
        </div>
        <div>
          <label for="password" class="form-label">Password</label>
          <input type="password" id="password" name="password" class="form-control" required>
        </div>
        <button type="submit" class="btn btn-primary btn-lg w-100">Create account</button>
        <div class="text-center my-3 text-muted">OR</div>
        <a href="/auth/google" class="google-btn">
          <img class="google-icon" src="https://img.icons8.com/?size=100&id=17949&format=png&color=000000" alt="Google Logo">
          <span>Sign up with Google</span>
        </a>
        <p class="text-center text-muted mt-4">Already have an account? <a class="auth-link" href="/login">Login here</a></p>
      </form>
    </div>
  </main>

  <footer class="footer">
    © <%= new Date().getFullYear() %> AI StudyPal
  </footer>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
