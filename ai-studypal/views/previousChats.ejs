<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Previous Chats | AI StudyPal</title>
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="/css/styles.css">
</head>
<body>
  <nav class="navbar navbar-expand-lg navbar-dark py-3">
    <div class="container">
      <a class="navbar-brand" href="/">AI StudyPal</a>
      <div class="ms-auto">
        <a class="btn btn-soft-light btn-sm" href="/">Home</a>
      </div>
    </div>
  </nav>

  <main class="container py-5">
    <section class="page-card p-4">
      <h1 class="section-title">Previous Chats</h1>
      <% if (chats.length === 0) { %>
        <p class="text-muted">No chats found yet. Start a new conversation to save your study sessions.</p>
      <% } else { %>
        <div class="list-card p-3">
          <div class="row g-3">
            <% chats.forEach(chat => { %>
              <div class="col-12">
                <a href="/chat/<%= chat._id %>" class="btn btn-soft-light w-100 text-start p-3">
                  <div class="d-flex justify-content-between align-items-start">
                    <div>
                      <strong><%= chat.title || 'Untitled Chat' %></strong>
                      <div class="text-muted mt-1"><%= new Date(chat.createdAt).toLocaleString('en-IN') %></div>
                    </div>
                    <span class="badge-soft">View</span>
                  </div>
                </a>
              </div>
            <% }) %>
          </div>
        </div>
      <% } %>
      <div class="text-end mt-4">
        <a href="/" class="btn btn-primary">← Back to Home</a>
      </div>
    </section>
  </main>

  <footer class="footer">
    © <%= new Date().getFullYear() %> AI StudyPal
  </footer>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
